<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Rocket SA: consultoría, ventas, marketing e inteligencia artificial para acelerar negocios." />
  <title>Rocket SA | Consultoría, Ventas, Marketing e IA</title>

  <style>
    :root {
      --bg: #fff9f2;
      --surface: rgba(255, 255, 255, 0.82);
      --surface-strong: #ffffff;
      --text: #17152f;
      --muted: #69647c;
      --primary: #6c2cff;
      --secondary: #ff3cac;
      --accent: #00d4ff;
      --lime: #b7ff3c;
      --orange: #ff8a00;
      --yellow: #ffd93d;
      --danger: #ff477e;
      --shadow: 0 24px 70px rgba(49, 24, 104, 0.16);
      --shadow-soft: 0 12px 32px rgba(49, 24, 104, 0.10);
      --radius-xl: 32px;
      --radius-lg: 24px;
      --radius-md: 18px;
      --transition: 260ms ease;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at 8% 4%, rgba(255, 60, 172, 0.22), transparent 24%),
        radial-gradient(circle at 90% 14%, rgba(0, 212, 255, 0.25), transparent 22%),
        radial-gradient(circle at 80% 86%, rgba(183, 255, 60, 0.22), transparent 24%),
        linear-gradient(140deg, #fff9f2 0%, #f9f3ff 50%, #effcff 100%);
      min-height: 100vh;
      overflow-x: hidden;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: -3;
      background-image:
        linear-gradient(rgba(108, 44, 255, 0.035) 1px, transparent 1px),
        linear-gradient(90deg, rgba(108, 44, 255, 0.035) 1px, transparent 1px);
      background-size: 40px 40px;
      mask-image: linear-gradient(to bottom, black, transparent 75%);
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    button,
    input,
    textarea {
      font: inherit;
    }

    img,
    svg {
      display: block;
      max-width: 100%;
    }

    .container {
      width: min(1180px, calc(100% - 40px));
      margin-inline: auto;
    }

    .section {
      padding: 100px 0;
      position: relative;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 9px 14px;
      border-radius: 999px;
      background: rgba(255,255,255,.72);
      border: 1px solid rgba(108, 44, 255, 0.14);
      box-shadow: var(--shadow-soft);
      color: var(--primary);
      font-size: .84rem;
      font-weight: 850;
      letter-spacing: .07em;
      text-transform: uppercase;
      backdrop-filter: blur(16px);
    }

    .eyebrow::before {
      content: "";
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--secondary), var(--orange));
      box-shadow: 0 0 0 6px rgba(255, 60, 172, .13);
      animation: pulse 2s infinite;
    }

    .section-title {
      margin-top: 22px;
      font-size: clamp(2.2rem, 5vw, 4.6rem);
      line-height: .98;
      letter-spacing: -0.055em;
      max-width: 900px;
    }

    .section-subtitle {
      margin-top: 22px;
      max-width: 720px;
      color: var(--muted);
      font-size: 1.08rem;
      line-height: 1.8;
    }

    .gradient-text {
      background: linear-gradient(90deg, var(--primary), var(--secondary), var(--orange));
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      background-size: 200% auto;
      animation: gradientMove 5s linear infinite;
    }

    /* NAV */
    .nav-wrap {
      position: fixed;
      top: 16px;
      left: 0;
      right: 0;
      z-index: 1000;
    }

    .nav {
      width: min(1180px, calc(100% - 28px));
      margin: auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 18px;
      padding: 12px 14px 12px 18px;
      border-radius: 999px;
      background: rgba(255,255,255,.78);
      border: 1px solid rgba(108, 44, 255, .12);
      box-shadow: 0 14px 42px rgba(48, 27, 92, .13);
      backdrop-filter: blur(22px);
    }

    .brand {
      display: inline-flex;
      align-items: center;
      gap: 11px;
      font-size: 1.05rem;
      font-weight: 950;
      white-space: nowrap;
    }

    .brand-mark {
      width: 42px;
      height: 42px;
      display: grid;
      place-items: center;
      border-radius: 15px;
      background: linear-gradient(135deg, var(--primary), var(--secondary), var(--orange));
      color: white;
      box-shadow: 0 10px 28px rgba(108, 44, 255, .35);
      transform: rotate(-7deg);
    }

    .brand-mark svg {
      width: 24px;
      height: 24px;
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 6px;
      list-style: none;
    }

    .nav-links a {
      display: inline-flex;
      padding: 10px 13px;
      border-radius: 999px;
      color: #4f4b61;
      font-size: .94rem;
      font-weight: 750;
      transition: var(--transition);
    }

    .nav-links a:hover,
    .nav-links a.active {
      color: var(--primary);
      background: rgba(108, 44, 255, .09);
    }

    .nav-cta {
      padding: 12px 18px;
      border-radius: 999px;
      background: linear-gradient(135deg, var(--primary), var(--secondary));
      color: white;
      font-size: .92rem;
      font-weight: 850;
      box-shadow: 0 12px 30px rgba(108, 44, 255, .28);
      transition: transform var(--transition), box-shadow var(--transition);
      white-space: nowrap;
    }

    .nav-cta:hover {
      transform: translateY(-2px) scale(1.02);
      box-shadow: 0 18px 38px rgba(108, 44, 255, .34);
    }

    .menu-btn {
      display: none;
      width: 46px;
      height: 46px;
      border: 0;
      border-radius: 14px;
      background: linear-gradient(135deg, var(--primary), var(--secondary));
      color: white;
      cursor: pointer;
    }

    .menu-btn svg {
      width: 24px;
      margin: auto;
    }

    /* HERO */
    .hero {
      padding: 165px 0 90px;
      min-height: 100vh;
      display: grid;
      align-items: center;
      position: relative;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 1.08fr .92fr;
      gap: 72px;
      align-items: center;
    }

    .hero h1 {
      margin-top: 24px;
      font-size: clamp(3.1rem, 7vw, 7.4rem);
      line-height: .86;
      letter-spacing: -0.078em;
      max-width: 850px;
    }

    .hero p {
      margin-top: 26px;
      color: var(--muted);
      font-size: clamp(1.05rem, 1.8vw, 1.26rem);
      line-height: 1.75;
      max-width: 650px;
    }

    .hero-actions {
      margin-top: 34px;
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      min-height: 56px;
      padding: 0 22px;
      border-radius: 16px;
      border: 1px solid transparent;
      font-weight: 900;
      transition: var(--transition);
      cursor: pointer;
    }

    .btn svg {
      width: 20px;
      height: 20px;
    }

    .btn-primary {
      color: white;
      background: linear-gradient(135deg, var(--primary), var(--secondary), var(--orange));
      background-size: 180% 180%;
      box-shadow: 0 18px 38px rgba(108, 44, 255, .26);
      animation: gradientMove 4s ease infinite;
    }

    .btn-primary:hover {
      transform: translateY(-4px) rotate(-1deg);
      box-shadow: 0 24px 50px rgba(108, 44, 255, .34);
    }

    .btn-secondary {
      background: rgba(255,255,255,.72);
      border-color: rgba(108, 44, 255, .14);
      color: var(--primary);
      backdrop-filter: blur(16px);
      box-shadow: var(--shadow-soft);
    }

    .btn-secondary:hover {
      transform: translateY(-4px);
      background: white;
    }

    .hero-mini {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 28px;
    }

    .hero-mini span {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 13px;
      border-radius: 999px;
      background: rgba(255,255,255,.66);
      border: 1px solid rgba(30, 28, 60, .08);
      color: #5d586f;
      font-size: .86rem;
      font-weight: 750;
      backdrop-filter: blur(12px);
    }

    .hero-visual {
      position: relative;
      min-height: 560px;
      display: grid;
      place-items: center;
    }

    .orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(1px);
      animation: float 6s ease-in-out infinite;
    }

    .orb.one {
      width: 160px;
      height: 160px;
      top: 12%;
      right: 3%;
      background: linear-gradient(135deg, rgba(255, 60, 172, .68), rgba(255, 138, 0, .72));
      box-shadow: inset 0 0 40px rgba(255,255,255,.35);
    }

    .orb.two {
      width: 95px;
      height: 95px;
      left: 4%;
      bottom: 13%;
      background: linear-gradient(135deg, rgba(0, 212, 255, .78), rgba(108, 44, 255, .65));
      animation-delay: -2s;
    }

    .orb.three {
      width: 54px;
      height: 54px;
      left: 7%;
      top: 18%;
      background: var(--lime);
      box-shadow: 0 0 50px rgba(183,255,60,.65);
      animation-delay: -3.5s;
    }

    .rocket-card {
      position: relative;
      width: min(460px, 92%);
      aspect-ratio: .86;
      border-radius: 42px;
      padding: 28px;
      background:
        linear-gradient(145deg, rgba(255,255,255,.9), rgba(255,255,255,.48)),
        linear-gradient(145deg, rgba(108,44,255,.2), rgba(0,212,255,.15));
      border: 1px solid rgba(255,255,255,.72);
      box-shadow: 0 34px 100px rgba(76, 28, 139, .24);
      backdrop-filter: blur(26px);
      overflow: hidden;
      transform: rotate(3deg);
      animation: cardFloat 6s ease-in-out infinite;
    }

    .rocket-card::before {
      content: "";
      position: absolute;
      inset: -20%;
      background: conic-gradient(
        from 45deg,
        rgba(108,44,255,.24),
        rgba(255,60,172,.22),
        rgba(255,138,0,.18),
        rgba(0,212,255,.2),
        rgba(108,44,255,.24)
      );
      animation: spin 14s linear infinite;
      filter: blur(18px);
    }

    .rocket-inner {
      position: relative;
      height: 100%;
      border-radius: 30px;
      background: linear-gradient(160deg, #17152f 0%, #2a145e 55%, #101933 100%);
      overflow: hidden;
      display: grid;
      place-items: center;
      padding: 30px;
    }

    .rocket-inner::after {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 15% 15%, rgba(255,255,255,.75) 0 1px, transparent 2px),
        radial-gradient(circle at 78% 28%, rgba(255,255,255,.8) 0 1.3px, transparent 2px),
        radial-gradient(circle at 35% 76%, rgba(255,255,255,.65) 0 1px, transparent 2px),
        radial-gradient(circle at 88% 82%, rgba(255,255,255,.8) 0 1.2px, transparent 2px);
      background-size: 120px 120px, 180px 180px, 160px 160px, 200px 200px;
      opacity: .7;
    }

    .rocket {
      position: relative;
      z-index: 2;
      width: 210px;
      animation: rocketFloat 3.8s ease-in-out infinite;
      filter: drop-shadow(0 25px 28px rgba(0,0,0,.25));
    }

    .rocket-flame {
      transform-origin: center top;
      animation: flame .55s ease-in-out infinite alternate;
    }

    .orbit-ring {
      position: absolute;
      z-index: 1;
      width: 310px;
      height: 130px;
      border: 2px solid rgba(255,255,255,.24);
      border-radius: 50%;
      transform: rotate(-20deg);
    }

    .orbit-dot {
      position: absolute;
      width: 16px;
      height: 16px;
      border-radius: 50%;
      background: var(--lime);
      box-shadow: 0 0 24px var(--lime);
      left: 12px;
      top: 45px;
      animation: orbitDot 4s ease-in-out infinite;
    }

    .floating-label {
      position: absolute;
      z-index: 4;
      padding: 11px 14px;
      border-radius: 14px;
      color: white;
      font-size: .78rem;
      font-weight: 850;
      backdrop-filter: blur(16px);
      box-shadow: 0 14px 32px rgba(0,0,0,.18);
    }

    .floating-label.a {
      top: 17%;
      left: 1%;
      background: linear-gradient(135deg, var(--secondary), var(--orange));
      animation: float 5s ease-in-out infinite;
    }

    .floating-label.b {
      bottom: 15%;
      right: 0;
      background: linear-gradient(135deg, var(--primary), var(--accent));
      animation: float 5.5s ease-in-out infinite -2s;
    }

    .scroll-indicator {
      position: absolute;
      left: 50%;
      bottom: 18px;
      transform: translateX(-50%);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 7px;
      color: var(--muted);
      font-size: .78rem;
      font-weight: 750;
    }

    .scroll-indicator span {
      width: 26px;
      height: 42px;
      border-radius: 999px;
      border: 2px solid rgba(108,44,255,.24);
      position: relative;
    }

    .scroll-indicator span::after {
      content: "";
      position: absolute;
      width: 5px;
      height: 10px;
      top: 7px;
      left: 50%;
      transform: translateX(-50%);
      border-radius: 999px;
      background: var(--primary);
      animation: scrollDown 1.8s infinite;
    }

    /* MARQUEE */
    .marquee-wrap {
      overflow: hidden;
      border-block: 1px solid rgba(108,44,255,.08);
      background: rgba(255,255,255,.5);
      backdrop-filter: blur(12px);
    }

    .marquee {
      display: flex;
      gap: 24px;
      width: max-content;
      padding: 16px 0;
      animation: marquee 26s linear infinite;
    }

    .marquee-item {
      display: inline-flex;
      align-items: center;
      gap: 11px;
      font-size: .95rem;
      font-weight: 900;
      letter-spacing: .04em;
      text-transform: uppercase;
      color: #3c3850;
      white-space: nowrap;
    }

    .marquee-item i {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--secondary), var(--orange));
      box-shadow: 0 0 0 6px rgba(255,60,172,.1);
    }

    /* SERVICES */
    .services-grid {
      margin-top: 54px;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }

    .service-card {
      position: relative;
      min-height: 330px;
      padding: 30px;
      border-radius: var(--radius-xl);
      overflow: hidden;
      border: 1px solid rgba(255,255,255,.7);
      box-shadow: var(--shadow);
      transition: transform var(--transition), box-shadow var(--transition);
      isolation: isolate;
    }

    .service-card:hover {
      transform: translateY(-10px) rotate(-.4deg);
      box-shadow: 0 34px 80px rgba(49,24,104,.23);
    }

    .service-card::after {
      content: "";
      position: absolute;
      width: 190px;
      height: 190px;
      border-radius: 50%;
      right: -55px;
      bottom: -55px;
      background: rgba(255,255,255,.26);
      filter: blur(2px);
      z-index: -1;
      transition: transform .55s ease;
    }

    .service-card:hover::after {
      transform: scale(1.35);
    }

    .service-card.consulting {
      background: linear-gradient(135deg, #7b2cff, #b62cff 58%, #ff3cac);
      color: white;
    }

    .service-card.sales {
      background: linear-gradient(135deg, #ff7a00, #ff3d77 70%, #ff3cac);
      color: white;
    }

    .service-card.marketing {
      background: linear-gradient(135deg, #00b8ff, #00d7c7 62%, #93ef3d);
      color: #102b3b;
    }

    .service-card.ai {
      background: linear-gradient(135deg, #17152f, #2c1e78 58%, #6c2cff);
      color: white;
    }

    .service-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 20px;
    }

    .service-icon {
      width: 62px;
      height: 62px;
      display: grid;
      place-items: center;
      border-radius: 20px;
      background: rgba(255,255,255,.18);
      border: 1px solid rgba(255,255,255,.32);
      backdrop-filter: blur(12px);
    }

    .service-icon svg {
      width: 32px;
      height: 32px;
    }

    .service-number {
      font-size: 3.5rem;
      line-height: 1;
      font-weight: 950;
      opacity: .2;
      letter-spacing: -.06em;
    }

    .service-card h3 {
      margin-top: 34px;
      font-size: clamp(1.8rem, 3vw, 2.8rem);
      letter-spacing: -.045em;
    }

    .service-card p {
      margin-top: 14px;
      line-height: 1.72;
      max-width: 520px;
      opacity: .88;
    }

    .service-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 9px;
      margin-top: 24px;
    }

    .service-tags span {
      padding: 8px 11px;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,.25);
      background: rgba(255,255,255,.13);
      font-size: .78rem;
      font-weight: 800;
      backdrop-filter: blur(8px);
    }

    .marketing .service-tags span {
      border-color: rgba(16,43,59,.13);
      background: rgba(255,255,255,.35);
    }

    /* VALUE */
    .value-shell {
      display: grid;
      grid-template-columns: .95fr 1.05fr;
      gap: 60px;
      align-items: center;
      padding: 52px;
      border-radius: 42px;
      background:
        linear-gradient(135deg, rgba(255,255,255,.88), rgba(255,255,255,.58)),
        linear-gradient(135deg, rgba(108,44,255,.12), rgba(0,212,255,.1));
      border: 1px solid rgba(255,255,255,.8);
      box-shadow: var(--shadow);
      backdrop-filter: blur(22px);
    }

    .value-visual {
      position: relative;
      min-height: 470px;
      border-radius: 30px;
      overflow: hidden;
      background:
        radial-gradient(circle at 70% 20%, rgba(255,255,255,.8), transparent 18%),
        linear-gradient(135deg, var(--secondary), var(--orange) 40%, var(--yellow) 68%, var(--lime));
      box-shadow: inset 0 0 0 1px rgba(255,255,255,.34);
    }

    .value-visual::before,
    .value-visual::after {
      content: "";
      position: absolute;
      border-radius: 50%;
      border: 2px solid rgba(255,255,255,.55);
    }

    .value-visual::before {
      width: 330px;
      height: 330px;
      left: -70px;
      bottom: -80px;
    }

    .value-visual::after {
      width: 220px;
      height: 220px;
      right: -40px;
      top: -50px;
    }

    .metric-card {
      position: absolute;
      border-radius: 22px;
      padding: 20px;
      background: rgba(255,255,255,.78);
      border: 1px solid rgba(255,255,255,.7);
      box-shadow: 0 18px 45px rgba(74,35,38,.16);
      backdrop-filter: blur(18px);
      animation: float 5s ease-in-out infinite;
    }

    .metric-card strong {
      display: block;
      font-size: 2rem;
      letter-spacing: -.05em;
    }

    .metric-card span {
      display: block;
      margin-top: 6px;
      font-size: .82rem;
      color: #5d5664;
      font-weight: 800;
    }

    .metric-card.one {
      top: 52px;
      left: 38px;
      width: 190px;
    }

    .metric-card.two {
      right: 34px;
      top: 190px;
      width: 180px;
      animation-delay: -1.8s;
    }

    .metric-card.three {
      left: 86px;
      bottom: 46px;
      width: 220px;
      animation-delay: -3.1s;
    }

    .chart {
      display: flex;
      align-items: end;
      gap: 9px;
      height: 95px;
      margin-top: 14px;
    }

    .chart i {
      flex: 1;
      border-radius: 7px 7px 2px 2px;
      background: linear-gradient(to top, var(--primary), var(--secondary));
      animation: bars 2.5s ease-in-out infinite alternate;
      transform-origin: bottom;
    }

    .chart i:nth-child(1) { height: 38%; animation-delay: -.2s; }
    .chart i:nth-child(2) { height: 62%; animation-delay: -.5s; }
    .chart i:nth-child(3) { height: 48%; animation-delay: -.8s; }
    .chart i:nth-child(4) { height: 82%; animation-delay: -1.1s; }
    .chart i:nth-child(5) { height: 100%; animation-delay: -1.4s; }

    .check-list {
      margin-top: 30px;
      display: grid;
      gap: 14px;
    }

    .check-item {
      display: flex;
      gap: 12px;
      align-items: flex-start;
      color: #4e4960;
      line-height: 1.6;
    }

    .check-icon {
      flex: 0 0 27px;
      width: 27px;
      height: 27px;
      display: grid;
      place-items: center;
      border-radius: 9px;
      color: white;
      background: linear-gradient(135deg, var(--primary), var(--secondary));
      box-shadow: 0 8px 18px rgba(108,44,255,.22);
      margin-top: 1px;
    }

    .check-icon svg {
      width: 15px;
      height: 15px;
    }

    /* PROCESS */
    .process-grid {
      margin-top: 52px;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 18px;
      position: relative;
    }

    .process-card {
      min-height: 260px;
      padding: 26px;
      border-radius: var(--radius-lg);
      background: rgba(255,255,255,.72);
      border: 1px solid rgba(108,44,255,.1);
      box-shadow: var(--shadow-soft);
      backdrop-filter: blur(16px);
      transition: transform var(--transition);
    }

    .process-card:hover {
      transform: translateY(-8px);
    }

    .process-step {
      width: 48px;
      height: 48px;
      display: grid;
      place-items: center;
      border-radius: 16px;
      color: white;
      font-weight: 950;
      background: linear-gradient(135deg, var(--primary), var(--secondary));
      box-shadow: 0 12px 28px rgba(108,44,255,.24);
    }

    .process-card:nth-child(2) .process-step {
      background: linear-gradient(135deg, var(--secondary), var(--orange));
    }

    .process-card:nth-child(3) .process-step {
      background: linear-gradient(135deg, var(--accent), #00c9a7);
    }

    .process-card:nth-child(4) .process-step {
      background: linear-gradient(135deg, var(--orange), var(--yellow));
      color: #2d2132;
    }

    .process-card h3 {
      margin-top: 24px;
      font-size: 1.3rem;
      letter-spacing: -.025em;
    }

    .process-card p {
      margin-top: 12px;
      color: var(--muted);
      line-height: 1.7;
      font-size: .94rem;
    }

    /* STATS */
    .stats-band {
      padding: 28px 0;
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 14px;
    }

    .stat {
      padding: 28px 20px;
      text-align: center;
      border-radius: 22px;
      background: rgba(255,255,255,.74);
      border: 1px solid rgba(108,44,255,.1);
      box-shadow: var(--shadow-soft);
      backdrop-filter: blur(14px);
    }

    .stat strong {
      display: block;
      font-size: clamp(2.2rem, 4vw, 4rem);
      line-height: 1;
      letter-spacing: -.06em;
      background: linear-gradient(90deg, var(--primary), var(--secondary), var(--orange));
      -webkit-background-clip: text;
      color: transparent;
    }

    .stat span {
      display: block;
      margin-top: 8px;
      color: var(--muted);
      font-size: .86rem;
      font-weight: 800;
    }

    /* CTA */
    .cta-box {
      position: relative;
      overflow: hidden;
      border-radius: 42px;
      padding: 70px 54px;
      color: white;
      background:
        radial-gradient(circle at 90% 20%, rgba(0,212,255,.42), transparent 24%),
        radial-gradient(circle at 12% 88%, rgba(255,60,172,.48), transparent 26%),
        linear-gradient(135deg, #15112d, #2f1469 52%, #6c2cff);
      box-shadow: 0 34px 90px rgba(32,16,69,.32);
    }

    .cta-box::before {
      content: "";
      position: absolute;
      inset: -60%;
      background: conic-gradient(
        transparent,
        rgba(255,255,255,.1),
        transparent 30%
      );
      animation: spin 10s linear infinite;
    }

    .cta-content {
      position: relative;
      z-index: 2;
      display: grid;
      grid-template-columns: 1.2fr .8fr;
      gap: 40px;
      align-items: center;
    }

    .cta-box h2 {
      font-size: clamp(2.5rem, 5vw, 5.2rem);
      line-height: .98;
      letter-spacing: -.06em;
      max-width: 800px;
    }

    .cta-box p {
      margin-top: 18px;
      max-width: 650px;
      color: rgba(255,255,255,.76);
      line-height: 1.7;
    }

    .cta-actions {
      display: flex;
      justify-content: flex-end;
      flex-wrap: wrap;
      gap: 12px;
    }

    .cta-actions .btn-secondary {
      background: white;
      color: var(--primary);
      border-color: transparent;
    }

    /* CONTACT */
    .contact-grid {
      margin-top: 50px;
      display: grid;
      grid-template-columns: .85fr 1.15fr;
      gap: 30px;
    }

    .contact-info,
    .contact-form {
      border-radius: var(--radius-xl);
      background: rgba(255,255,255,.76);
      border: 1px solid rgba(108,44,255,.1);
      box-shadow: var(--shadow);
      backdrop-filter: blur(18px);
    }

    .contact-info {
      padding: 34px;
      overflow: hidden;
      position: relative;
    }

    .contact-info::after {
      content: "";
      position: absolute;
      width: 250px;
      height: 250px;
      border-radius: 50%;
      right: -100px;
      bottom: -100px;
      background: linear-gradient(135deg, rgba(255,60,172,.28), rgba(0,212,255,.28));
      filter: blur(4px);
    }

    .contact-info h3 {
      font-size: 2rem;
      letter-spacing: -.04em;
    }

    .contact-info p {
      margin-top: 14px;
      color: var(--muted);
      line-height: 1.7;
    }

    .contact-list {
      margin-top: 28px;
      display: grid;
      gap: 14px;
    }

    .contact-list a,
    .contact-list div {
      display: flex;
      align-items: center;
      gap: 13px;
      padding: 14px;
      border-radius: 15px;
      background: rgba(108,44,255,.06);
      color: #4a455c;
      font-weight: 750;
      position: relative;
      z-index: 2;
    }

    .contact-list .icon {
      width: 40px;
      height: 40px;
      display: grid;
      place-items: center;
      border-radius: 13px;
      color: white;
      background: linear-gradient(135deg, var(--primary), var(--secondary));
    }

    .contact-list svg {
      width: 20px;
      height: 20px;
    }

    .socials {
      margin-top: 30px;
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      position: relative;
      z-index: 2;
    }

    .social-link {
      width: 46px;
      height: 46px;
      display: grid;
      place-items: center;
      border-radius: 15px;
      background: white;
      border: 1px solid rgba(108,44,255,.1);
      box-shadow: var(--shadow-soft);
      transition: var(--transition);
    }

    .social-link:hover {
      transform: translateY(-5px) rotate(-4deg);
      color: white;
      background: linear-gradient(135deg, var(--primary), var(--secondary));
    }

    .social-link svg {
      width: 21px;
      height: 21px;
    }

    .contact-form {
      padding: 34px;
    }

    .form-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    .field {
      display: grid;
      gap: 8px;
    }

    .field.full {
      grid-column: 1 / -1;
    }

    .field label {
      color: #454055;
      font-size: .86rem;
      font-weight: 850;
    }

    .field input,
    .field textarea,
    .field select {
      width: 100%;
      border: 1px solid rgba(108,44,255,.13);
      background: rgba(255,255,255,.84);
      border-radius: 15px;
      padding: 15px 16px;
      color: var(--text);
      outline: none;
      transition: border-color var(--transition), box-shadow var(--transition), transform var(--transition);
    }

    .field textarea {
      min-height: 140px;
      resize: vertical;
    }

    .field input:focus,
    .field textarea:focus,
    .field select:focus {
      border-color: var(--primary);
      box-shadow: 0 0 0 4px rgba(108,44,255,.11);
      transform: translateY(-1px);
    }

    .form-note {
      margin-top: 12px;
      color: var(--muted);
      font-size: .78rem;
      line-height: 1.5;
    }

    /* FOOTER */
    footer {
      padding: 30px 0 36px;
    }

    .footer-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 18px;
      padding-top: 24px;
      border-top: 1px solid rgba(108,44,255,.1);
      color: var(--muted);
      font-size: .88rem;
    }

    .footer-links {
      display: flex;
      flex-wrap: wrap;
      gap: 18px;
    }

    .footer-links a:hover {
      color: var(--primary);
    }

    /* FLOAT BUTTON */
    .float-btn {
      position: fixed;
      right: 20px;
      bottom: 20px;
      z-index: 999;
      width: 58px;
      height: 58px;
      display: grid;
      place-items: center;
      border: 0;
      border-radius: 20px;
      color: white;
      background: linear-gradient(135deg, #20c975, #00a95c);
      box-shadow: 0 18px 40px rgba(0,169,92,.32);
      cursor: pointer;
      transition: var(--transition);
    }

    .float-btn:hover {
      transform: translateY(-5px) rotate(-4deg) scale(1.04);
    }

    .float-btn svg {
      width: 27px;
      height: 27px;
    }

    .toast {
      position: fixed;
      left: 50%;
      bottom: 28px;
      z-index: 2000;
      transform: translate(-50%, 30px);
      padding: 14px 18px;
      border-radius: 14px;
      background: #17152f;
      color: white;
      box-shadow: 0 18px 50px rgba(0,0,0,.3);
      opacity: 0;
      pointer-events: none;
      transition: .35s ease;
      font-weight: 750;
      text-align: center;
      width: min(520px, calc(100% - 30px));
    }

    .toast.show {
      opacity: 1;
      transform: translate(-50%, 0);
    }

    /* REVEAL */
    .reveal {
      opacity: 0;
      transform: translateY(36px);
      transition: opacity .75s ease, transform .75s ease;
    }

    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* ANIMATIONS */
    @keyframes gradientMove {
      0% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }

    @keyframes pulse {
      0%, 100% { transform: scale(1); opacity: 1; }
      50% { transform: scale(.72); opacity: .65; }
    }

    @keyframes float {
      0%, 100% { transform: translateY(0) rotate(0); }
      50% { transform: translateY(-16px) rotate(3deg); }
    }

    @keyframes cardFloat {
      0%, 100% { transform: rotate(3deg) translateY(0); }
      50% { transform: rotate(1deg) translateY(-12px); }
    }

    @keyframes rocketFloat {
      0%, 100% { transform: translateY(0) rotate(-4deg); }
      50% { transform: translateY(-14px) rotate(3deg); }
    }

    @keyframes flame {
      from { transform: scaleY(.82); opacity: .8; }
      to { transform: scaleY(1.2); opacity: 1; }
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    @keyframes orbitDot {
      0%, 100% { transform: translate(0, 0); }
      50% { transform: translate(250px, 40px); }
    }

    @keyframes scrollDown {
      0% { opacity: 0; transform: translate(-50%, 0); }
      40% { opacity: 1; }
      100% { opacity: 0; transform: translate(-50%, 16px); }
    }

    @keyframes marquee {
      to { transform: translateX(-50%); }
    }

    @keyframes bars {
      to { transform: scaleY(.72); opacity: .76; }
    }

    /* RESPONSIVE */
    @media (max-width: 980px) {
      .nav-links,
      .nav-cta {
        display: none;
      }

      .menu-btn {
        display: grid;
        place-items: center;
      }

      .nav.open {
        align-items: flex-start;
        border-radius: 26px;
        flex-wrap: wrap;
      }

      .nav.open .nav-links {
        display: grid;
        width: 100%;
        order: 3;
        padding: 8px 0 4px;
      }

      .nav.open .nav-links a {
        padding: 12px 14px;
      }

      .hero-grid,
      .value-shell,
      .cta-content,
      .contact-grid {
        grid-template-columns: 1fr;
      }

      .hero {
        padding-top: 145px;
      }

      .hero-visual {
        min-height: 510px;
      }

      .hero h1 {
        max-width: 780px;
      }

      .services-grid {
        grid-template-columns: 1fr;
      }

      .process-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .stats-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .cta-actions {
        justify-content: flex-start;
      }
    }

    @media (max-width: 660px) {
      .container {
        width: min(100% - 24px, 1180px);
      }

      .section {
        padding: 74px 0;
      }

      .hero {
        padding-top: 128px;
      }

      .hero h1 {
        font-size: clamp(3.2rem, 16vw, 5.6rem);
      }

      .hero-actions {
        display: grid;
      }

      .btn {
        width: 100%;
      }

      .hero-visual {
        min-height: 430px;
      }

      .rocket-card {
        width: 96%;
        padding: 18px;
        border-radius: 30px;
      }

      .rocket-inner {
        border-radius: 24px;
      }

      .rocket {
        width: 160px;
      }

      .orbit-ring {
        width: 250px;
      }

      .floating-label.a {
        top: 7%;
      }

      .floating-label.b {
        bottom: 6%;
      }

      .value-shell,
      .cta-box {
        padding: 28px 20px;
        border-radius: 28px;
      }

      .value-visual {
        min-height: 420px;
      }

      .metric-card.one {
        top: 30px;
        left: 20px;
      }

      .metric-card.two {
        right: 18px;
        top: 182px;
      }

      .metric-card.three {
        left: 34px;
        bottom: 30px;
      }

      .process-grid,
      .stats-grid,
      .form-grid {
        grid-template-columns: 1fr;
      }

      .field.full {
        grid-column: auto;
      }

      .service-card {
        padding: 24px;
      }

      .contact-info,
      .contact-form {
        padding: 24px;
      }

      .footer-inner {
        align-items: flex-start;
        flex-direction: column;
      }

      .scroll-indicator {
        display: none;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      *,
      *::before,
      *::after {
        animation-duration: .01ms !important;
        animation-iteration-count: 1 !important;
        scroll-behavior: auto !important;
      }

      .reveal {
        opacity: 1;
        transform: none;
      }
    }
  </style>
